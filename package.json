{
  "name": "wastewater-treatment-plant",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:all": "node run-all.cjs",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "node server.cjs",
    "start": "node start.cjs",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npx @electron/rebuild --force --arch=x64 --electron-version=40.6.0 && npm run build && electron-builder --config electron-builder.config.cjs && npm run validate:native",
    "electron:publish": "npx @electron/rebuild --force --arch=x64 --electron-version=40.6.0 && npm run build && electron-builder --config electron-builder.config.cjs --publish always",
    "validate": "node scripts/validate-release.cjs",
    "validate:asar": "node scripts/validate-release.cjs --asar-path ./release/win-unpacked/resources/app.asar",
    "validate:api": "node scripts/validate-release.cjs --api-test",
    "validate:native": "node scripts/validate-packaged-native.cjs ./release/win-unpacked",
    "package:field-installer": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-integrated-installer.ps1 -AppVersion 1.1.0",
    "validate:field-installer": "node scripts/validate-field-installer.cjs",
    "clean:release": "node scripts/clean-release.cjs",
    "release:safe": "npm run clean:release && npm rebuild better-sqlite3 && npm run build && npm run validate && npm run validate:api && npm run electron:build && npm run package:field-installer && npm run validate:field-installer && npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^8.1.1",
    "@heroicons/react": "^2.2.0",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "firebase-admin": "^13.10.0",
    "googleapis": "^171.4.0",
    "jszip": "^3.10.1",
    "multer": "^2.0.2",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "quill-resize-module": "^2.1.3",
    "react": "^19.2.0",
    "react-calendar": "^6.0.0",
    "react-dom": "^19.2.0",
    "react-quill-new": "^3.8.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1"
  }
}
